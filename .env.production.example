# Copy this file to .env on the production host before running
# `docker compose -f docker-compose.prod.yml up -d --build`.
#
# Anything that starts with a comment "#" is ignored.

# ---- Public surface --------------------------------------------------
# Fully-qualified origin(s) of the frontend (comma-separated, no path).
# Used by FastAPI's CORS middleware.
CORS_ORIGINS=https://anatomia.example.com

# ---- Secrets ---------------------------------------------------------
# Anything that signs cookies / JWTs goes through this key.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-48-char-random-string

# ---- Database --------------------------------------------------------
# SQLite stored on the host under ./data/anatomia.db and bind-mounted
# into the container at /data/anatomia.db. The default below is fine
# unless you move to Postgres later.
DATABASE_URL=sqlite:////data/anatomia.db

# ---- Logging / runtime ----------------------------------------------
APP_ENV=production
